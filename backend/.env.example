# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=change_this_to_a_long_random_secret

# ── Local development (default) ──
DB_TYPE=sqlite
DB_PATH=./data/chronosynapse.db

# ── Render / cloud PostgreSQL (recommended for production) ──
# DB_TYPE=postgres
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# DB_SSL=true

# ── Cloud MySQL (PlanetScale, Aiven, Railway, etc.) ──
# DB_TYPE=mysql
# DB_HOST=your-mysql-host.com
# DB_PORT=3306
# DB_USER=your_user
# DB_PASSWORD=your_password
# DB_NAME=chronosynapse
# DB_SSL=true

# Optional: only needed if frontend is hosted on a different domain
# FRONTEND_URL=https://your-frontend.onrender.com,https://yourname.github.io
